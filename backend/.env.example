# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/devyly_db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email
# Local geliştirme: console backend (terminale yazar, gerçek mail göndermez)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Devyly <noreply@devyly.com>
SERVER_EMAIL=noreply@devyly.com
EMAIL_PROVIDER=CONSOLE
# Production SMTP örnek (Resend/Brevo/SendGrid):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_USE_SSL=True
# EMAIL_USE_TLS=False
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=your-api-key

# Frontend URL (password reset linkleri için)
FRONTEND_URL=http://localhost:3000
