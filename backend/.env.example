# ============================================================
# Devyly Backend — Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur.
# ============================================================

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-in-production

# ── Mode ─────────────────────────────────────────────────────
DEBUG=True

# ── Hosts & CORS (virgülle ayrılmış) ─────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/devyly_db

# ── Frontend URL (email doğrulama ve şifre sıfırlama linkleri için) ──
FRONTEND_URL=http://localhost:3000

# ── API Docs Basic Auth (/api/docs/ ve /api/schema/ için) ─────────────
# Boş bırakılırsa koruma devre dışı (development için uygundur).
DOCS_BASIC_AUTH_USERNAME=
DOCS_BASIC_AUTH_PASSWORD=

# ── Email — Development (konsola yazar, gerçek mail göndermez) ───────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Devyly <noreply@devyly.com>
SERVER_EMAIL=noreply@devyly.com
EMAIL_PROVIDER=CONSOLE

# ============================================================
# Production overrides
# Aşağıdaki satırları production .env'de aktif et,
# yukarıdaki development değerlerini kaldır veya yorum satırına al.
# ============================================================

# SECRET_KEY=50-karakterlik-rastgele-dizi
# DEBUG=False
# ALLOWED_HOSTS=api.devyly.com
# CORS_ALLOWED_ORIGINS=https://devyly.com
# FRONTEND_URL=https://devyly.com
# DATABASE_URL=postgresql://user:password@db-host:5432/devyly_prod

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_YOUR_RESEND_API_KEY
# DEFAULT_FROM_EMAIL=Devyly <noreply@devyly.com>
# SERVER_EMAIL=noreply@devyly.com
# EMAIL_PROVIDER=SMTP
